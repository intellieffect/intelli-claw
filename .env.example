# OpenClaw Gateway WebSocket URL
VITE_GATEWAY_URL=ws://127.0.0.1:18789

# Gateway auth token (optional)
# VITE_GATEWAY_TOKEN=

# Default agent ID (optional)
# VITE_DEFAULT_AGENT=default

# Allowed hosts for external access (comma-separated)
# Required when accessing dev server via hostname (e.g. Tailscale)
# ALLOWED_HOSTS=my-hostname,my-hostname.tailnet.ts.net

# ── PM2 ecosystem config ──
# PROJECT_ROOT=/path/to/intelli-claw
# TAILSCALE_FQDN=my-machine.tailnet.ts.net
