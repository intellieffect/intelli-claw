{
  "name": "intelli-claw",
  "version": "0.2.5",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "pnpm --filter @intelli-claw/web dev",
    "build": "turbo run build",
    "preview": "pnpm --filter @intelli-claw/web preview",
    "dev:electron": "pnpm --filter @intelli-claw/desktop dev",
    "build:electron": "pnpm --filter @intelli-claw/desktop build",
    "version:bump": "bash scripts/bump-version.sh",
    "release": "bash scripts/release.sh",
    "package": "pnpm --filter @intelli-claw/desktop package",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:server": "pnpm --filter @intelli-claw/server dev",
    "dev:mobile": "pnpm --filter @intelli-claw/mobile dev",
    "deploy:local": "bash scripts/deploy.sh local",
    "deploy:macbook": "bash scripts/deploy.sh macbook",
    "deploy:all": "bash scripts/deploy.sh all"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "turbo": "^2.5.0",
    "typescript-eslint": "^8.33.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "react-native-mmkv"
    ],
    "overrides": {
      "@types/react": "~19.1.0",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "dependencies": {
    "electron": "^40.6.1"
  }
}
