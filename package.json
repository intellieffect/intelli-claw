{
  "name": "intelli-claw",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "pnpm --filter @intelli-claw/web dev",
    "build": "turbo run build",
    "preview": "pnpm --filter @intelli-claw/web preview",
    "dev:electron": "pnpm --filter @intelli-claw/desktop dev",
    "build:electron": "pnpm --filter @intelli-claw/desktop build",
    "package": "pnpm --filter @intelli-claw/desktop package",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:server": "pnpm --filter @intelli-claw/server dev",
    "dev:mobile": "pnpm --filter @intelli-claw/mobile dev"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "react-native-mmkv"
    ],
    "overrides": {
      "@types/react": "~19.0.0"
    }
  }
}
