{
  "name": "intelli-claw",
  "version": "0.2.32",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "pnpm --filter @intelli-claw/web dev",
    "dev:electron": "pnpm --filter @intelli-claw/desktop dev",
    "build": "turbo run build",
    "build:electron": "pnpm --filter @intelli-claw/desktop build",
    "package": "pnpm --filter @intelli-claw/desktop package",
    "preview": "pnpm --filter @intelli-claw/web preview",
    "version:bump": "bash scripts/bump-version.sh",
    "release": "bash scripts/release.sh",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "turbo": "^2.5.0",
    "typescript-eslint": "^8.33.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "@types/react": "~19.1.0",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
