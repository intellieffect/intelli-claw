{
  "name": "@intelli-claw/desktop",
  "version": "0.2.6",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "prepackage": "bash ../../scripts/check-version-bump.sh",
    "package": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@intelli-claw/shared": "workspace:*",
    "@intelli-claw/web": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.6.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.openclaw.intelli-claw",
    "productName": "iClaw",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!node_modules"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "../../resources/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "../../resources/icon.ico"
    }
  }
}
