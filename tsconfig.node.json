{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "out"
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/server/**/*.ts",
    "electron.vite.config.ts"
  ]
}
